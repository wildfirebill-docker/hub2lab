# Server
PORT=3000

# GitHub
GITHUB_TOKEN=ghp_your_github_pat
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# GitLab
GITLAB_TOKEN=glpat-your-gitlab-pat
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret
GITLAB_BASE_URL=https://gitlab.com

# Mapping file (JSON)
MAPPING_FILE=./mapping.json

# Mirrors directory (temp storage for git operations)
MIRROR_DIR=./mirrors

# Sync marker — commits containing this string are ignored (prevents loops)
SYNC_MARKER=[hub2lab]

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
